    {
      "name": "06 - Rental Requests",
      "item": [
        {
          "name": "Submit Rental Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"01KX3NW25QGD2M2FEQ702B0A91\",\n  \"message\": \"I am very interested in this property and would like to move in by the requested date.\",\n  \"moveInDate\": \"2027-09-01T00:00:00.000Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/rentals",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "rentals"
              ]
            },
            "description": "Tenant submits a request to rent a property. New requests always start at status `PENDING` — `status` is not an accepted field here and cannot be set by the client. Role: TENANT."
          },
          "response": []
        },
        {
          "name": "Get My Rental Requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rentals",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "rentals"
              ]
            },
            "description": "List rental requests. Tenants see only their own; landlords see requests on their properties; admins see all. Roles: TENANT, LANDLORD, ADMIN."
          },
          "response": []
        },
        {
          "name": "Get Rental Request By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rentals/:requestId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "rentals",
                ":requestId"
              ],
              "variable": [
                {
                  "key": "requestId",
                  "value": "189f938c-9178-45fb-994f-492eb826504b"
                }
              ]
            },
            "description": "Get full details of a single rental request. Roles: TENANT (own request only), LANDLORD (own property only), ADMIN."
          },
          "response": []
        },
        {
          "name": "Update Rental Request Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/rentals/:id/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "rentals",
                ":id",
                "status"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "189f938c-9178-45fb-994f-492eb826504b"
                }
              ]
            },
            "description": "Approve or reject a pending request, or progress an approved one. Allowed transitions: `PENDING → APPROVED/REJECTED`, `APPROVED → ACTIVE`, `ACTIVE → COMPLETED`. Admins may override this and set any status directly (e.g. for a manually-confirmed cash payment). Roles: LANDLORD (own property only), ADMIN."
          },
          "response": []
        }
      ],
      "description": "The core rental workflow: a tenant requests a property, a landlord (or admin) approves/rejects it, and its status progresses through PENDING → APPROVED → ACTIVE → COMPLETED (or REJECTED)."
    },
