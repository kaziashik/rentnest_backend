
model User {
    id        String     @id @default(ulid())
    name      String     @db.VarChar(255)
    email     String     @unique
    password String
    role      Role       @default(TENANT)
    phone     String?
    photo     String?
    activeStatus    UserStatus @default(ACTIVE)
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt

    // A user with role LANDLORD owns many properties
  properties     Property[]      @relation("LandlordProperties")
  //a user with role tenant submit many rental requests

  rentalRequest RentalRequest[] @relation("TenantRentalRequests")

    // A user with role TENANT writes many reviews
  reviews        Review[]        @relation("TenantReviews")
}
